# Copy to .env.local and fill in.

# Postgres (docker-compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/certificate_poc?schema=public

# Optional: pin a server identity key (otherwise .server-wallet.json is auto-generated).
# SERVER_PRIVATE_KEY=

# Optional: custom DID resolver / WoC endpoints (defaults are fine for most usage).
# DID_RESOLVER_URL=
# WOC_BASE_URL=https://api.whatsonchain.com
